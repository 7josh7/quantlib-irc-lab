{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs2022-x64-static",
      "displayName": "VS 2022 x64 static vcpkg",
      "description": "Build with MSVC, the Visual Studio bundled vcpkg, and x64-windows-static.",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "binaryDir": "$env{USERPROFILE}/irc-build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "vs2022-x64-static-coverage",
      "displayName": "VS 2022 x64 static coverage",
      "description": "Build with MSVC static native coverage instrumentation.",
      "inherits": "vs2022-x64-static",
      "binaryDir": "$env{USERPROFILE}/irc-coverage-build",
      "cacheVariables": {
        "IRC_ENABLE_MSVC_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "vs2022-x64-static",
      "configuration": "Release"
    },
    {
      "name": "coverage",
      "displayName": "RelWithDebInfo coverage",
      "configurePreset": "vs2022-x64-static-coverage",
      "configuration": "RelWithDebInfo"
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "displayName": "Release tests",
      "configurePreset": "vs2022-x64-static",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "displayName": "RelWithDebInfo coverage tests",
      "configurePreset": "vs2022-x64-static-coverage",
      "configuration": "RelWithDebInfo",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
